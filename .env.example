# Morada AO - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/morada_ao
DATABASE_URL_SHADOW=postgresql://user:password@localhost:5432/morada_ao_shadow

# ==========================================
# SERVER
# ==========================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ==========================================
# API KEYS & TOKENS
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION=30d

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Nominatim (Reverse Geocoding)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=your-email@example.com

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# PostHog (Product Analytics)
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_API_URL=https://app.posthog.com

# ==========================================
# EXPO / MOBILE
# ==========================================
EXPO_PACKAGER_PROXY_URL=https://your-replit-domain
REACT_NATIVE_PACKAGER_HOSTNAME=your-replit-domain
EXPO_PUBLIC_DOMAIN=your-replit-domain:5000

# ==========================================
# CORS & SECURITY
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com
ALLOWED_HOSTS=localhost,yourdomain.com

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================
# FEATURES
# ==========================================
FEATURE_HISTORY=true
FEATURE_FAVORITES=true
FEATURE_BUSINESS_PORTAL=false
FEATURE_GIS_PORTAL=false
FEATURE_API_PUBLIC=false

# ==========================================
# REPLIT (Development)
# ==========================================
REPLIT_DEV_DOMAIN=your-replit-dev-domain
REPLIT_DOMAINS=your-replit-domain-1,your-replit-domain-2